---
import Base from '../../layouts/Base.astro';
import { StackDetailPage } from '../../components/detail-pages.jsx';
import { STACKS } from '../../data/stacks.js';

export function getStaticPaths() {
  return STACKS.map((s) => ({
    params: { slug: s.slug },
    props: { stack: s },
  }));
}

const { stack } = Astro.props;
const title = `${stack.name} — ${stack.goal} protocol | FitLab`;
const description = `${stack.short} ${stack.components.length} ingredients, ~${stack.monthly}/month.`;
---
<Base title={title} description={description}>
  <StackDetailPage stack={stack} client:load />
</Base>
