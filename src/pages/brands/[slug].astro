---
import Base from '../../layouts/Base.astro';
import { BrandDetail, BRANDS } from '../../components/brands.jsx';

export function getStaticPaths() {
  return BRANDS.map((b) => ({
    params: { slug: b.slug },
    props: { brand: b },
  }));
}

const { brand } = Astro.props;
const title = `${brand.name} — Brand Review — FitLab`;
const description = `Independent FitLab brand review for ${brand.name}. ${brand.short}`;
---
<Base title={title} description={description}>
  <BrandDetail slug={brand.slug} client:load />
</Base>
