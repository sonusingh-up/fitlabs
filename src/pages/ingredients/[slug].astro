---
import Base from '../../layouts/Base.astro';
import { IngredientDetailPage } from '../../components/detail-pages.jsx';
import { INGREDIENTS } from '../../data/ingredients.js';

export function getStaticPaths() {
  return INGREDIENTS.map((i) => ({
    params: { slug: i.slug },
    props: { ingredient: i },
  }));
}

const { ingredient } = Astro.props;
const title = `${ingredient.name} — Evidence, dose & mechanism | FitLab`;
const description = `${ingredient.short} Dose: ${ingredient.dose}. ${ingredient.citations} cited studies.`;
---
<Base title={title} description={description}>
  <IngredientDetailPage ingredient={ingredient} client:load />
</Base>
