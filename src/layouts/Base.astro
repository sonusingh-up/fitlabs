---
import '../styles/tokens.css';
const {
  title = 'FitLab — Evidence-based supplement reviews',
  description = 'Independent, research-backed supplement reviews. Every recommendation cites the underlying science. Zero paid placements.',
  canonical,
  image = '/icon-192.png',
} = Astro.props;
const url = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#0F766E" />
  <meta name="robots" content="index,follow" />
  <meta name="author" content="FitLab Science Team" />
  <link rel="canonical" href={url} />
  <link rel="icon" href="/favicon.ico" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={url} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, Astro.site).toString()} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <link rel="sitemap" href="/sitemap.xml" />
  <style is:global>html,body{margin:0;padding:0;}</style>
  <slot name="head" />
</head>
<body>
  <slot />
</body>
</html>
