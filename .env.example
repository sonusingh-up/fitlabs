# Amazon Creators API / Product Advertising API
# Get credentials from: https://webservices.amazon.com/paapi5/documentation/register-for-pa-api.html
# or the Creators API dashboard

AMAZON_CLIENT_ID=amzn1.application-oa2-client.your-client-id-here
AMAZON_CLIENT_SECRET=your-client-secret-here
AMAZON_PARTNER_TAG=supplementstr-20

# Resend email service
RESEND_API_KEY=re_your-resend-api-key-here
ADMIN_EMAIL=your-notification-email@example.com

# Google Analytics (optional — falls back to hardcoded ID if unset)
NEXT_PUBLIC_GA_ID=G-N23DKB7H8K

# Supabase — Auth + database
NEXT_PUBLIC_SUPABASE_URL=https://szpdxovusioijennckfg.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Sanity CMS (existing)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_WRITE_TOKEN=
